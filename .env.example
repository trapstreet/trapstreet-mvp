# Copy to .env.local and fill in.

# Neon Postgres (https://neon.tech, free tier).
# Use the "pooled connection" string.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generate with: openssl rand -hex 32
AUTH_SECRET=""

# GitHub OAuth (https://github.com/settings/developers)
# - Homepage: http://localhost:3000
# - Callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
# - Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# When deploying to Vercel, also add these in the dashboard. Vercel auto-sets
# AUTH_TRUST_HOST=true; for self-hosted Node you may need to set it manually.
